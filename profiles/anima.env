# AIO - leave VAE, LLM params empty

BINARY=sd-cli
MODEL=models/Anima-P3-Turbo-AIO-Q4_K.gguf 
VAE=
LLM=
BACKEND=llm=cpu
PROMPT="masterpiece, best quality, score_8, an anime girl holding a simple red apple, wearing a oversized hoodie. Soft pastel style"
NEGATIVE_PROMPT=
WIDTH=512
HEIGHT=768
STEPS=8
CFG_SCALE=1.0
GUIDANCE=
SEED=-1
BATCH_COUNT=1
OUTPUT_BEGIN_IDX=
MAX_VRAM=-0.01
SAMPLING_METHOD=er_sde
SCHEDULER=smoothstep
CACHE_MODE=spectrum
CACHE_OPTION=
STRENGTH=0.75
HIRES=false
HIRES_SCALE=2.0
HIRES_DENOISING_STRENGTH=0.7
HIRES_STEPS=0
SLG_SCALE=
SKIP_LAYERS=
VAE_TILE_SIZE=
CIRCULAR=false
DISABLE_IMAGE_METADATA=false
OUTPUT=output/output_anima.png
VAE_TILING=true
OFFLOAD_TO_CPU=false
DIFFUSION_FA=false
