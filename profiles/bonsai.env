BINARY=sd-cli
MODEL=models/Bonsai/bonsai_image_4b-q1_0.gguf
VAE=models/Bonsai/flux2-vae.safetensors
LLM=models/Bonsai/Qwen3-4B-UD-IQ1_M.gguf
BACKEND=llm=gpu
PROMPT="a girl holding a red apple"
NEGATIVE_PROMPT=
WIDTH=512
HEIGHT=512
STEPS=6
CFG_SCALE=1.0
GUIDANCE=3.5
SEED=-1
BATCH_COUNT=1
OUTPUT_BEGIN_IDX=
MAX_VRAM=-0.1
SAMPLING_METHOD=dpm++2s_a
SCHEDULER=discrete
CACHE_MODE=none
CACHE_OPTION=
STRENGTH=0.75
HIRES=false
HIRES_SCALE=2.0
HIRES_DENOISING_STRENGTH=0.7
HIRES_STEPS=0
SLG_SCALE=
SKIP_LAYERS=
VAE_TILE_SIZE=
CIRCULAR=false
DISABLE_IMAGE_METADATA=false
OUTPUT=output/output_bonsai_%03d.png
VAE_TILING=true
OFFLOAD_TO_CPU=true
DIFFUSION_FA=false
